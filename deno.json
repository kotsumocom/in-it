{
  "workspace": [
    "./packages/in-it"
  ],
  "tasks": {
    "dev": "deno run -A --watch server/main.ts",
    "dev:client": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "check": "deno check server/main.ts client/main.tsx"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/jsx": "npm:hono@^4/jsx",
    "hono/jsx/dom": "npm:hono@^4/jsx/dom",
    "@in-it/": "./packages/in-it/src/"
  },
  "nodeModulesDir": "auto"
}
