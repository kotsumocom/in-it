{
  "workspace": [
    "./packages/in-it",
    "./create-in-it"
  ],
  "tasks": {
    "check": "deno check packages/in-it/src/mod.ts",
    "build:styles": "deno run -A scripts/build-styles.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/jsx": "npm:hono@^4/jsx",
    "hono/jsx/dom": "npm:hono@^4/jsx/dom"
  },
  "nodeModulesDir": "auto"
}
