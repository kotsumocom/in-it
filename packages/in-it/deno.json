{
  "name": "@kotsumo/in-it",
  "version": "0.2.2",
  "description": "Zero-dependency SaaS starter framework for Hono + Deno/Bun. HCT color system, WAI-ARIA components, MD3 theming, SPA router, and markdown parser -- everything is in it.",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts",
    "./aria": "./src/aria/mod.ts",
    "./components": "./src/components/mod.ts",
    "./color": "./src/color/hct.ts",
    "./color/scheme": "./src/color/scheme.ts",
    "./color/presets": "./src/color/presets.ts",
    "./docs": "./src/docs/markdown.ts",
    "./router": "./src/router.tsx"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "lib": ["deno.window", "dom", "dom.iterable"]
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/jsx": "npm:hono@^4/jsx",
    "hono/jsx/dom": "npm:hono@^4/jsx/dom",
    "hono/jsx/jsx-runtime": "npm:hono@^4/jsx/jsx-runtime",
    "hono/jsx/jsx-dev-runtime": "npm:hono@^4/jsx/jsx-dev-runtime"
  },
  "publish": {
    "include": ["src/", "LICENSE", "README.md"]
  }
}
